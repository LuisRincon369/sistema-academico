# ─── Twilio WhatsApp ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── PostgreSQL en Render ───
DATABASE_URL=postgresql://usuario:password@host:5432/sistema_academico

# ─── Servidor ───
PORT=3000
NODE_ENV=production

# ─── URL pública del webhook (R3: validación de firma Twilio) ───
# Debe coincidir exactamente con la URL configurada en Twilio Console
WEBHOOK_URL=https://TU-APP.onrender.com/webhook/whatsapp

# ─── Clave de cifrado AES-256 para notion_token (R2) ───
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: guardar esta clave en un lugar seguro — perderla hace irrecuperables los tokens
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
